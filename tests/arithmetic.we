; Tests the four arithmetic operators: + - * /
(define (add a b) (+ a b))
(define (sub a b) (- a b))
(define (mul a b) (* a b))
(define (div a b) (/ a b))

(define (main)
  (begin
    (define x (add 10 5))   ; 15
    (define y (sub x 3))    ; 12
    (define z (mul y 2))    ; 24
    (define w (div z 4))    ; 6
    0))

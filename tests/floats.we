# Tests that 3f14-style float literals are accepted by the lexer.
# The runtime uses i64, so fractional parts are truncated at compile time:
#   3f14 -> 3, 1f9 -> 1, 2f0 -> 2, -0f5 -> 0.
#
# This test verifies two things:
#   1. The 3f14 syntax parses without error (compile-time check).
#   2. The truncated integer values behave correctly at runtime.

main:
  {(3f0.equals 3):
    {((multiply [3f0, 2f0]).equals 6):
      {(1f9.equals 1):
        {(3f14.equals 3): 0, _: 1},
      _: 1},
    _: 1},
  _: 1}

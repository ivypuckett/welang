; Tests if/else, including the optional else-less form.
abs: (x)
  (if (< x 0)
    (- 0 x)
    x)

max: (a b)
  (if (> a b) a b)

min: (a b)
  (if (< a b) a b)

; if without else returns 0 when condition is false
positive-only: (x)
  (if (> x 0) x)

main: ()
  (begin
    (define a (abs -7))          ; 7
    (define b (abs 3))           ; 3
    (define c (max 4 9))         ; 9
    (define d (min 4 9))         ; 4
    (define e (positive-only 5)) ; 5
    (define f (positive-only -1)); 0
    0)

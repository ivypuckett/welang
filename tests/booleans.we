; Tests that boolean literals #t and #f compile to 1 and 0 respectively,
; and that they can be used as conditions and passed as arguments.
bool-result: (if [x, 1, 0])

main:
  (if [(= [#t, 1]),
    (if [(= [#f, 0]),
      (if [(= [(bool-result #t), 1]),
        (if [(= [(bool-result #f), 0]),
          0,
          1]),
        1]),
      1]),
    1])

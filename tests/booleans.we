# Tests that boolean literals true and false compile to 1 and 0 respectively,
# and that they can be used as conditions and passed as arguments.
bool-result: (if [x, 1, 0])

main:
  (if [(eq [true, 1]),
    (if [(eq [false, 0]),
      (if [(eq [(bool-result true), 1]),
        (if [(eq [(bool-result false), 0]),
          0,
          1]),
        1]),
      1]),
    1])
